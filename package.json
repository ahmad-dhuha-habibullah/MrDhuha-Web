{
  "name": "mrdhuha-web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm-run-all build:*",
    "build:11ty": "npx @11ty/eleventy",
    "build:css": "npx @tailwindcss/cli -i ./src/assets/css/input.css -o ./_site/assets/css/style.css",
    "start": "npm-run-all --parallel start:*",
    "start:11ty": "npx @11ty/eleventy --serve",
    "start:css": "npx @tailwindcss/cli -i ./src/assets/css/input.css -o ./_site/assets/css/style.css --watch",
    "deploy": "npm run build:11ty && wrangler deploy",
    "preview": "npm run build:11ty && wrangler dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@tailwindcss/cli": "^4.3.0",
    "luxon": "^3.7.2",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.3.0",
    "wrangler": "^4.99.0"
  },
  "dependencies": {
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2"
  }
}
