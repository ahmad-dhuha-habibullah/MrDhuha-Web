<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default(site.name) }}</title>
    <meta name="description" content="{{ description | default(site.description) }}">
    <meta name="author" content="{{ author | default(site.author) }}">
    
    <!-- Open Graph / Social Media Meta Tags -->
    <meta property="og:title" content="{{ title | default(site.name) }}">
    <meta property="og:description" content="{{ description | default(site.description) }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    {% if thumbnail %}
    <meta property="og:image" content="{{ site.url }}{{ thumbnail | resolveAsset(page.inputPath) }}">
    {% else %}
    <meta property="og:image" content="{{ site.url }}/assets/MrDhuhaLogo.png">
    {% endif %}

    <!-- Google Search Console Verification (Replace content with your actual code later) -->
    <meta name="google-site-verification" content="YOUR_GOOGLE_VERIFICATION_CODE_HERE" />
    <!-- CSS -->
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://unpkg.com/prismjs@1.29.0/themes/prism-okaidia.min.css">
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&display=swap"
        rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Dark Mode Init (Anti-flash) -->
    <script>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>

    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="601f8664-f21a-4563-9c6f-f0407589ad1d"></script>
</head>

<body class="antialiased flex flex-col min-h-screen">

    <!-- Sticky Container for Nav + Announcement -->
    <div class="sticky top-0 z-50 flex flex-col">
        <!-- Navigation -->
        <header class="bg-surface border-b border-border">
            <div class="container mx-auto px-4 lg:px-8 py-4 flex justify-between items-center">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3">
                <img src="/assets/MrDhuhaLogo.png" alt="Mr Dhuha Logo" class="w-10 h-10 object-contain">
                <div class="flex flex-col">
                    <span class="font-bold text-xl leading-tight text-text">Mr Dhuha</span>
                    <span class="text-[10px] text-textLight">Menjelaskan dunia dengan data.</span>
                </div>
            </a>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-text">
                <a href="/" class="nav-link {% if page.url == '/' %}active{% endif %}">Beranda</a>
                <a href="/artikel/" class="nav-link {% if '/artikel/' in page.url or '/articles/' in page.url %}active{% endif %}">Artikel</a>
                <a href="/video/" class="nav-link {% if '/video/' in page.url or '/videos/' in page.url %}active{% endif %}">Video</a>
                <a href="/topik/" class="nav-link {% if '/topik/' in page.url %}active{% endif %}">Topik</a>
                <a href="/seri/" class="nav-link {% if '/seri/' in page.url or '/series/' in page.url %}active{% endif %}">Series</a>
                <a href="/eksplorasi/" class="nav-link {% if '/eksplorasi/' in page.url or '/explorations/' in page.url %}active{% endif %}">Eksplorasi</a>
                <a href="/tentang/" class="nav-link {% if '/tentang/' in page.url or '/about/' in page.url %}active{% endif %}">Tentang</a>
            </nav>

            <!-- Search, Theme & Mobile Menu -->
            <div class="flex items-center gap-4">
                <button id="theme-toggle" class="p-2 text-text hover:text-primary transition-colors" aria-label="Toggle Dark Mode">
                    <i data-lucide="moon" class="w-5 h-5"></i>
                </button>
                <button onclick="toggleSearchModal()" class="p-2 text-text hover:text-primary transition-colors cursor-pointer" aria-label="Search">
                    <i data-lucide="search" class="w-5 h-5"></i>
                </button>
                <button class="md:hidden p-2 text-text" id="mobile-menu-btn">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
            </div>
        </div>
        <!-- Mobile Nav (Hidden by default) -->
        <nav id="mobile-nav" class="hidden md:hidden bg-surface border-t border-border px-4 py-2 flex flex-col gap-2 shadow-md">
            <a href="/" class="nav-link block py-2 {% if page.url == '/' %}text-primary font-bold{% endif %}">Beranda</a>
            <a href="/artikel/" class="nav-link block py-2 {% if '/artikel/' in page.url or '/articles/' in page.url %}text-primary font-bold{% endif %}">Artikel</a>
            <a href="/video/" class="nav-link block py-2 {% if '/video/' in page.url or '/videos/' in page.url %}text-primary font-bold{% endif %}">Video</a>
            <a href="/topik/" class="nav-link block py-2 {% if '/topik/' in page.url %}text-primary font-bold{% endif %}">Topik</a>
            <a href="/seri/" class="nav-link block py-2 {% if '/seri/' in page.url or '/series/' in page.url %}text-primary font-bold{% endif %}">Series</a>
            <a href="/eksplorasi/" class="nav-link block py-2 {% if '/eksplorasi/' in page.url or '/explorations/' in page.url %}text-primary font-bold{% endif %}">Eksplorasi</a>
            <a href="/tentang/" class="nav-link block py-2 {% if '/tentang/' in page.url or '/about/' in page.url %}text-primary font-bold{% endif %}">Tentang</a>
        </nav>
    </header>

    <!-- Announcement Bar -->
    {% if announcement.enabled %}
    <div id="announcementBar" style="background-color: {{ announcement.background_color | default('#1e293b') }}" class="text-white text-sm font-medium py-2 px-4 flex justify-center items-center w-full z-40 border-b border-black/10 shadow-sm relative transition-all duration-300">
        <div class="text-center px-8">
            {{ announcement.text | safe }}
            {% if announcement.link_url and announcement.link_text %}
            <a href="{{ announcement.link_url }}" class="ml-2 underline font-bold hover:text-primary transition-colors">{{ announcement.link_text }}</a>
            {% endif %}
        </div>
        {% if announcement.closable %}
        <button onclick="closeAnnouncement()" class="absolute right-4 top-1/2 transform -translate-y-1/2 hover:opacity-75 transition-opacity" aria-label="Tutup pengumuman">
            <i data-lucide="x" class="w-5 h-5"></i>
        </button>
        {% endif %}
    </div>
    {% endif %}
    </div>

    <!-- Main Content Area -->
    <main id="app-root" class="flex-grow">
        {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="bg-surface border-t border-border mt-16 pt-12 pb-8">
        <div class="container mx-auto px-4 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="flex items-center gap-3">
                    <img src="/assets/MrDhuhaLogo.png" alt="Mr Dhuha Logo" class="w-8 h-8 object-contain grayscale opacity-60">
                    <span class="text-sm text-textLight">&copy; 2026 Mr Dhuha. Menjelaskan dunia dengan data.</span>
                </div>

                <div class="flex gap-4 items-center">
                    <a href="#" class="text-textLight hover:text-primary"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
                    <a href="#" class="text-textLight hover:text-primary"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
                    <a href="#" class="text-textLight hover:text-primary"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg></a>
                    <a href="/tentang/" class="text-textLight hover:text-primary"><i data-lucide="mail" class="w-5 h-5"></i></a>
                </div>
            </div>

            <div class="mt-8 flex justify-center md:justify-end gap-6 text-xs text-textLight">
                <a href="/privasi/" class="hover:text-text transition-colors">Privasi</a>
                <a href="/tentang/" class="hover:text-text transition-colors">Kontak</a>
                <a href="/peta-situs/" class="hover:text-primary transition-colors font-semibold">Peta Situs</a>
            </div>
        </div>
    </footer>

    <!-- Include Share Modal -->
    {% include "components/share-modal.njk" %}

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-4 left-1/2 transform -translate-x-1/2 bg-slate-900 text-white px-6 py-3 rounded-full text-sm font-medium shadow-2xl opacity-0 transition-opacity pointer-events-none z-[110]">
        <!-- message goes here -->
    </div>

    <!-- Fullscreen Search Modal -->
    <div id="searchModal" class="fixed inset-0 bg-surface/95 backdrop-blur-sm z-[200] hidden flex-col items-center pt-20 px-4">
        <button onclick="toggleSearchModal()" class="absolute top-6 right-6 p-2 text-textLight hover:text-text bg-slate-100 dark:bg-slate-800 rounded-full transition-colors">
            <i data-lucide="x" class="w-6 h-6"></i>
        </button>
        <div class="w-full max-w-3xl">
            <div class="relative mb-8">
                <i data-lucide="search" class="absolute left-4 top-1/2 transform -translate-y-1/2 w-6 h-6 text-textLight"></i>
                <input type="text" id="modalSearchInput" placeholder="Cari artikel, video, atau topik..." class="w-full bg-white dark:bg-slate-900 border-2 border-border rounded-2xl py-4 pl-14 pr-4 text-lg focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all text-text shadow-lg">
            </div>
            
            <div id="modalSearchState" class="space-y-4 max-h-[70vh] overflow-y-auto pb-8 pr-2 custom-scrollbar">
                <!-- Bookmarks will be shown here by default -->
                <div id="modalBookmarksSection" class="hidden mb-6">
                    <h3 class="text-lg font-bold text-text mb-4 flex items-center gap-2">
                        <i data-lucide="bookmark" class="w-5 h-5 text-primary"></i>
                        Halaman Tersimpan
                    </h3>
                    <div id="modalBookmarksList" class="space-y-3"></div>
                </div>

                <!-- Latest suggestions shown by default -->
                <div id="modalSuggestionsSection" class="hidden">
                    <h3 class="text-lg font-bold text-text mb-4 flex items-center gap-2">
                        <i data-lucide="sparkles" class="w-5 h-5 text-primary"></i>
                        Terbaru
                    </h3>
                    <div id="modalSuggestionsList" class="space-y-3"></div>
                </div>

                <!-- Search results injected here via JS -->
                <div id="modalSearchResults" class="space-y-4 hidden"></div>
            </div>
        </div>
    </div>

    <!-- Promo CTA Modal -->
    {% if promo.enabled %}
    <div id="promoModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[150] hidden items-center justify-center p-4">
        <div class="bg-surface rounded-2xl shadow-2xl w-full max-w-md overflow-hidden relative transform transition-all scale-95 opacity-0 duration-300" id="promoModalCard">
            <button onclick="closePromoModal()" class="absolute top-4 right-4 z-10 p-2 text-textLight hover:text-text bg-white/50 dark:bg-black/50 rounded-full backdrop-blur-md transition-colors">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
            {% if promo.image %}
            <div class="w-full aspect-video bg-slate-200 dark:bg-slate-800">
                <img src="{{ promo.image | resolveAsset('/') }}" alt="Promo Image" class="w-full h-full object-cover">
            </div>
            {% endif %}
            <div class="p-8 text-center">
                <h3 class="text-2xl font-bold text-text mb-3">{{ promo.heading }}</h3>
                <p class="text-textLight mb-8">{{ promo.description }}</p>
                <a href="{{ promo.cta_url }}" class="inline-block w-full bg-primary hover:bg-orange-600 text-white font-bold py-3 px-6 rounded-xl transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                    Pelajari Lebih Lanjut
                </a>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Fuse.js for Search -->
    <script src="https://cdn.jsdelivr.net/npm/fuse.js/dist/fuse.js"></script>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Dark Mode Toggle
        const themeToggleBtn = document.getElementById('theme-toggle');
        
        function updateThemeIcon() {
            if (document.documentElement.getAttribute('data-theme') === 'dark') {
                themeToggleBtn.innerHTML = '<i data-lucide="sun" class="w-5 h-5"></i>';
            } else {
                themeToggleBtn.innerHTML = '<i data-lucide="moon" class="w-5 h-5"></i>';
            }
            lucide.createIcons();
        }

        if (themeToggleBtn) {
            updateThemeIcon();
            themeToggleBtn.addEventListener('click', function() {
                if (document.documentElement.getAttribute('data-theme') === 'dark') {
                    document.documentElement.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                }
                updateThemeIcon();
                // Send message to Giscus if it exists
                const iframe = document.querySelector('iframe.giscus-frame');
                if (iframe) {
                    const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'transparent_dark' : 'light';
                    iframe.contentWindow.postMessage({ giscus: { setConfig: { theme: theme } } }, 'https://giscus.app');
                }
            });
        }

        // Mobile menu toggle
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileNav = document.getElementById('mobile-nav');
        if (menuBtn && mobileNav) {
            menuBtn.addEventListener('click', () => {
                mobileNav.classList.toggle('hidden');
            });
        }

        // Toast logic
        let toastTimeout;
        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            
            clearTimeout(toastTimeout);
            toastTimeout = setTimeout(() => {
                toast.classList.remove('opacity-100');
                toast.classList.add('opacity-0');
            }, 3000);
        }

        // Bookmark system
        function toggleBookmark(url, title) {
            let bookmarks = JSON.parse(localStorage.getItem('mrdhuha_bookmarks') || '[]');
            const existingIndex = bookmarks.findIndex(b => b.url === url);
            
            if (existingIndex >= 0) {
                bookmarks.splice(existingIndex, 1);
                showToast('Dihapus dari markah (bookmark).');
            } else {
                bookmarks.push({ url, title, date: new Date().toISOString() });
                showToast('Tersimpan di markah (bookmark)!');
            }
            
            localStorage.setItem('mrdhuha_bookmarks', JSON.stringify(bookmarks));
            updateBookmarkUI();
        }

        function updateBookmarkUI() {
            let bookmarks = JSON.parse(localStorage.getItem('mrdhuha_bookmarks') || '[]');
            const currentUrl = window.location.pathname;
            
            // If on article page
            const icon = document.getElementById('bookmarkIcon');
            const text = document.getElementById('bookmarkText');
            
            if (icon && text) {
                const isBookmarked = bookmarks.some(b => currentUrl.includes(b.url) && b.url !== '/');
                // The icon could be the <i> tag or the initialized <svg>
                const btn = icon.closest('button');
                if (isBookmarked) {
                    icon.classList.add('text-primary', 'fill-current');
                    text.classList.add('text-primary');
                    if (btn) btn.classList.add('border-primary', 'bg-orange-50', 'dark:bg-orange-900/20');
                    text.innerText = 'Tersimpan';
                } else {
                    icon.classList.remove('text-primary', 'fill-current');
                    text.classList.remove('text-primary');
                    if (btn) btn.classList.remove('border-primary', 'bg-orange-50', 'dark:bg-orange-900/20');
                    text.innerText = 'Simpan';
                }
            }

            // Update all bookmark buttons on article cards (like in index or topik pages)
            const cardBtns = document.querySelectorAll('.bookmark-btn-card');
            cardBtns.forEach(btn => {
                const url = btn.getAttribute('data-bookmark-url');
                // Use strict equality for cards because their url is exact
                const isBookmarked = bookmarks.some(b => b.url === url);
                const btnIcon = btn.querySelector('svg') || btn.querySelector('i');
                
                if (isBookmarked) {
                    btn.classList.add('text-primary');
                    if(btnIcon) btnIcon.classList.add('fill-current');
                } else {
                    btn.classList.remove('text-primary');
                    if(btnIcon) btnIcon.classList.remove('fill-current');
                }
            });
        }

        // Run on load
        document.addEventListener('DOMContentLoaded', () => {
            updateBookmarkUI();

            // Add copy buttons to code blocks
            document.querySelectorAll('.article-content pre').forEach((pre) => {
                // Wrap pre in a relative container
                const wrapper = document.createElement('div');
                wrapper.className = 'relative group mb-6';
                pre.parentNode.insertBefore(wrapper, pre);
                wrapper.appendChild(pre);
                
                // Remove existing bottom margin from pre since wrapper has it
                pre.style.marginBottom = '0';

                // Create button
                const btn = document.createElement('button');
                btn.className = 'absolute top-2 right-2 bg-slate-700 hover:bg-primary text-white p-2 rounded opacity-0 group-hover:opacity-100 transition-all shadow-md focus:opacity-100 outline-none';
                btn.title = "Salin kode";
                btn.innerHTML = '<i data-lucide="copy" class="w-4 h-4"></i>';
                wrapper.appendChild(btn);

                btn.addEventListener('click', () => {
                    navigator.clipboard.writeText(pre.textContent.trim()).then(() => {
                        btn.innerHTML = '<i data-lucide="check" class="w-4 h-4 text-green-400"></i>';
                        lucide.createIcons({ root: wrapper });
                        setTimeout(() => {
                            btn.innerHTML = '<i data-lucide="copy" class="w-4 h-4"></i>';
                            lucide.createIcons({ root: wrapper });
                        }, 2000);
                    });
                });
            });
            
            // Re-initialize icons for newly injected buttons
            lucide.createIcons();
        });

        // Promo Modal Logic
        {% if promo.enabled %}
        document.addEventListener('DOMContentLoaded', () => {
            const promoClosedDate = localStorage.getItem('mrdhuha_promo_closed');
            const now = new Date().getTime();
            const threeDays = 3 * 24 * 60 * 60 * 1000;
            
            if (!promoClosedDate || (now - parseInt(promoClosedDate)) > threeDays) {
                // Show modal after a small delay
                setTimeout(() => {
                    const modal = document.getElementById('promoModal');
                    const card = document.getElementById('promoModalCard');
                    if (modal && card) {
                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        // Trigger reflow
                        void modal.offsetWidth;
                        card.classList.remove('scale-95', 'opacity-0');
                        card.classList.add('scale-100', 'opacity-100');
                    }
                }, 1500);
            }
        });
        
        function closePromoModal() {
            const modal = document.getElementById('promoModal');
            const card = document.getElementById('promoModalCard');
            if (modal && card) {
                card.classList.remove('scale-100', 'opacity-100');
                card.classList.add('scale-95', 'opacity-0');
                setTimeout(() => {
                    modal.classList.remove('flex');
                    modal.classList.add('hidden');
                }, 300);
                
                // Save to localStorage
                localStorage.setItem('mrdhuha_promo_closed', new Date().getTime().toString());
            }
        }
        {% endif %}

        // Search Modal Logic
        let searchIndex = null;
        let fuse = null;

        function toggleSearchModal() {
            const modal = document.getElementById('searchModal');
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.style.overflow = 'hidden';
                document.getElementById('modalSearchInput').focus();
                
                // Show bookmarks by default
                renderBookmarksInModal();
                
                // Fetch index if not loaded
                if (!fuse) {
                    fetch('/search.json')
                        .then(res => res.json())
                        .then(data => {
                            searchIndex = data;
                            fuse = new Fuse(searchIndex, {
                                keys: ['title', 'description', 'type', 'topic'],
                                includeScore: true,
                                threshold: 0.4
                            });
                            renderSuggestionsInModal();
                        });
                } else {
                    renderSuggestionsInModal();
                }
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                document.body.style.overflow = '';
            }
        }

        function renderSuggestionsInModal() {
            const suggestionsSection = document.getElementById('modalSuggestionsSection');
            const suggestionsList = document.getElementById('modalSuggestionsList');
            const searchInput = document.getElementById('modalSearchInput');
            
            if (searchInput.value.trim() !== '' || !searchIndex) {
                suggestionsSection.classList.add('hidden');
                return;
            }

            suggestionsSection.classList.remove('hidden');
            let html = '';
            // Show top 5 latest items
            searchIndex.slice(0, 5).forEach(item => {
                html += `
                <a href="${item.url}" class="block bg-surface border border-border p-4 rounded-xl hover:shadow-md hover:border-primary/50 transition-all group">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-bold text-lg text-text group-hover:text-primary transition-colors">${item.title}</h3>
                        <span class="text-xs font-bold px-2 py-1 bg-slate-100 dark:bg-slate-800 text-textLight rounded uppercase tracking-wider">${item.type}</span>
                    </div>
                    <p class="text-sm text-textLight line-clamp-2">${item.description}</p>
                </a>`;
            });
            suggestionsList.innerHTML = html;
        }

        function renderBookmarksInModal() {
            let bookmarks = JSON.parse(localStorage.getItem('mrdhuha_bookmarks') || '[]');
            const bookmarksSection = document.getElementById('modalBookmarksSection');
            const bookmarksList = document.getElementById('modalBookmarksList');
            const searchResults = document.getElementById('modalSearchResults');
            const searchInput = document.getElementById('modalSearchInput');
            
            if (searchInput.value.trim() !== '') {
                bookmarksSection.classList.add('hidden');
                return;
            }

            searchResults.classList.add('hidden');

            if (bookmarks.length > 0) {
                bookmarksSection.classList.remove('hidden');
                let html = '';
                bookmarks.forEach(b => {
                    html += `
                    <a href="${b.url}" class="block bg-surface border border-border p-4 rounded-xl hover:shadow-md hover:border-primary/50 transition-all group flex items-center justify-between">
                        <span class="font-bold text-base text-text group-hover:text-primary transition-colors">${b.title}</span>
                        <i data-lucide="external-link" class="w-4 h-4 text-textLight group-hover:text-primary"></i>
                    </a>`;
                });
                bookmarksList.innerHTML = html;
                lucide.createIcons({ root: bookmarksList });
            } else {
                bookmarksSection.classList.add('hidden');
            }
        }

        document.getElementById('modalSearchInput')?.addEventListener('input', function(e) {
            const query = e.target.value;
            const resultsContainer = document.getElementById('modalSearchResults');
            const bookmarksSection = document.getElementById('modalBookmarksSection');
            const suggestionsSection = document.getElementById('modalSuggestionsSection');
            
            if (!query || query.trim() === '') {
                resultsContainer.innerHTML = '';
                resultsContainer.classList.add('hidden');
                renderBookmarksInModal();
                renderSuggestionsInModal();
                return;
            }
            
            bookmarksSection.classList.add('hidden');
            suggestionsSection.classList.add('hidden');
            resultsContainer.classList.remove('hidden');
            
            if (!fuse) return;
            
            const results = fuse.search(query);
            
            if (results.length === 0) {
                resultsContainer.innerHTML = `<p class="text-textLight text-center py-8">Tidak ada hasil ditemukan untuk "<b>${query}</b>".</p>`;
                return;
            }
            
            let html = '';
            results.slice(0, 10).forEach(result => {
                const item = result.item;
                html += `
                <a href="${item.url}" class="block bg-surface border border-border p-4 rounded-xl hover:shadow-md hover:border-primary/50 transition-all group">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-bold text-lg text-text group-hover:text-primary transition-colors">${item.title}</h3>
                        <span class="text-xs font-bold px-2 py-1 bg-slate-100 dark:bg-slate-800 text-textLight rounded uppercase tracking-wider">${item.type}</span>
                    </div>
                    <p class="text-sm text-textLight line-clamp-2">${item.description}</p>
                </a>`;
            });
            
            resultsContainer.innerHTML = html;
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const searchModal = document.getElementById('searchModal');
                const promoModal = document.getElementById('promoModal');
                if (searchModal && !searchModal.classList.contains('hidden')) {
                    toggleSearchModal();
                }
                if (promoModal && !promoModal.classList.contains('hidden')) {
                    closePromoModal();
                }
            }
        });

        function closeAnnouncement() {
            document.getElementById('announcementBar').classList.add('hidden');
            sessionStorage.setItem('announcementClosed', 'true');
        }

        if (sessionStorage.getItem('announcementClosed') === 'true') {
            const ann = document.getElementById('announcementBar');
            if (ann) ann.classList.add('hidden');
        }
    </script>
</body>

</html>
