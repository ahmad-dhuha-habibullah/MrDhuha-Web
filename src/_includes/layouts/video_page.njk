---
layout: layouts/base.njk
---
{% from "components/macros.njk" import contentCard, paginationNav %}

<div class="container mx-auto px-4 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <nav class="flex items-center gap-2 text-sm text-textLight mb-4">
                <a href="/" class="hover:text-primary transition-colors">Beranda</a>
                <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
                <span class="text-text font-medium truncate">Video</span>
            </nav>
            <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-4">{{ page_heading }}</h1>
            <p class="text-lg text-textLight max-w-2xl font-serif">{{ page_description }}</p>
        </div>
        
        <div class="w-full md:w-64 relative">
            <input type="text" id="globalPageSearchInput" data-collection="Video" placeholder="Cari video..." class="w-full bg-surface border border-border rounded-full py-2 px-4 pr-10 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-text">
            <i data-lucide="search" class="absolute right-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-textLight"></i>
        </div>
    </div>

    {% if content %}
    <!-- CMS WYSIWYG Content -->
    <div class="prose prose-lg prose-slate dark:prose-invert max-w-4xl mx-auto mb-12">
        {{ content | safe }}
    </div>
    {% endif %}

    <!-- Content Grid -->
    <div id="contentGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {% for item in videos %}
            {{ contentCard(item, true) }}
        {% endfor %}
    </div>

    <!-- Pagination -->
    {{ paginationNav(pagination) }}
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('globalPageSearchInput');
        const grid = document.getElementById('contentGrid');
        const pagination = document.getElementById('paginationControls');
        const originalContent = grid ? grid.innerHTML : '';
        
        if (!searchInput || !grid) return;
        
        const collectionType = searchInput.getAttribute('data-collection');
        
        function renderSearchCard(item) {
            let topicHtml = item.topic ? `
                <div class="absolute bottom-2 right-2 bg-surface/90 backdrop-blur-sm text-primary text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">
                    ${item.topic}
                </div>` : '';
                
            let isVideo = item.type === 'Video';
            let playIcon = isVideo ? `
                <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors">
                    <div class="w-12 h-12 bg-black/60 rounded-full flex items-center justify-center backdrop-blur-sm">
                        <i data-lucide="play" class="w-5 h-5 text-white ml-1"></i>
                    </div>
                </div>` : '';
                
            let tagHtml = '';
            if (!isVideo && item.topic) {
                tagHtml = `<a href="/topik/${item.topic.toLowerCase().replace(/ /g, '-')}/" class="text-xs font-bold text-primary uppercase tracking-wider mb-2 hover:underline">${item.topic}</a>`;
            }
            
            let dateHtml = '';
            if (item.date) {
                const date = new Date(item.date).toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'});
                dateHtml = `<span class="flex items-center gap-1"><i data-lucide="${isVideo ? 'calendar' : 'clock'}" class="w-4 h-4"></i>${isVideo ? '' : '5 menit baca &middot; '} ${date}</span>`;
            }

            return `
            <article class="bg-surface rounded-xl border border-border overflow-hidden card-hover flex flex-col h-full">
                <a href="${item.url}" class="block relative aspect-[16/9] overflow-hidden bg-gray-100 group">
                    ${item.thumbnail ? `<img src="${item.thumbnail}" alt="${item.title}" class="object-cover w-full h-full">` : ''}
                    ${playIcon}
                    ${topicHtml}
                </a>
                
                <div class="p-5 flex flex-col flex-grow">
                    ${tagHtml}
                    <a href="${item.url}" class="block group">
                        <h3 class="font-bold text-lg leading-snug mb-3 text-text group-hover:text-primary transition-colors">${item.title}</h3>
                    </a>
                    <div class="mt-auto flex items-center justify-between text-sm text-textLight">
                        ${dateHtml}
                        <button class="bookmark-btn-card hover:text-primary z-10 relative" aria-label="Simpan" data-bookmark-url="${item.url}" onclick="event.preventDefault(); toggleBookmark('${item.url}', '${item.title.replace(/'/g, "\\'")}')"><i data-lucide="bookmark" class="w-4 h-4"></i></button>
                    </div>
                </div>
            </article>`;
        }

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.trim().toLowerCase();
            
            if (!query) {
                grid.innerHTML = originalContent;
                if (pagination) pagination.style.display = 'flex';
                lucide.createIcons();
                return;
            }
            
            if (pagination) pagination.style.display = 'none';
            
            fetch('/search.json')
                .then(res => res.json())
                .then(data => {
                    const results = data.filter(item => 
                        item.type === collectionType && 
                        (item.title.toLowerCase().includes(query) || item.description.toLowerCase().includes(query))
                    );
                    
                    if (results.length === 0) {
                        grid.innerHTML = `<p class="col-span-full text-center text-textLight py-8">Tidak ada hasil yang ditemukan untuk "<b>${query}</b>" di ${collectionType}.</p>`;
                        return;
                    }
                    
                    let html = '';
                    results.forEach(item => {
                        html += renderSearchCard(item);
                    });
                    
                    grid.innerHTML = html;
                    lucide.createIcons();
                });
        });
    });
</script>
