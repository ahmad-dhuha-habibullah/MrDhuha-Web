---
layout: layouts/base.njk
---

<div class="container mx-auto px-4 lg:px-8 py-12">
    <div class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <nav class="flex items-center gap-2 text-sm text-textLight mb-4">
                <a href="/" class="hover:text-primary transition-colors">Beranda</a>
                <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
                <span class="text-text font-medium truncate">Topik</span>
            </nav>
            <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-4">{{ page_heading }}</h1>
            <p class="text-lg text-textLight max-w-2xl font-serif">{{ page_description }}</p>
        </div>
        
        <div class="w-full md:w-64 relative">
            <input type="text" id="globalPageSearchInput" data-collection="Topik" placeholder="Cari topik..." class="w-full bg-surface border border-border rounded-full py-2 px-4 pr-10 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-text">
            <i data-lucide="search" class="absolute right-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-textLight"></i>
        </div>
    </div>

    {% if content %}
    <!-- CMS WYSIWYG Content -->
    <div class="prose prose-lg prose-slate dark:prose-invert max-w-4xl mx-auto mb-16">
        {{ content | safe }}
    </div>
    {% endif %}

    <div id="contentGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for item in collections.topics %}
            <a href="{{ item.url }}" class="group block border border-border rounded-2xl overflow-hidden hover:border-primary hover:shadow-lg transition-all bg-surface">
                <div class="h-48 relative overflow-hidden bg-slate-100 dark:bg-slate-800">
                    {% if item.data.thumbnail %}
                    <img src="{{ item.data.thumbnail }}" alt="{{ item.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    {% else %}
                    <div class="w-full h-full flex items-center justify-center bg-slate-200 dark:bg-slate-800">
                        <i data-lucide="folder" class="w-12 h-12 text-slate-400"></i>
                    </div>
                    {% endif %}
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent"></div>
                </div>
                <div class="p-6">
                    <h2 class="text-xl font-bold text-text mb-2 group-hover:text-primary transition-colors">{{ item.data.title }}</h2>
                    {% if item.data.description %}
                    <p class="text-sm text-textLight mb-4 line-clamp-2">{{ item.data.description }}</p>
                    {% endif %}
                    <div class="flex items-center justify-between pt-4 border-t border-border">
                        {% set itemCount = (item.data.itemList | default([])) | length %}
                        <span class="text-sm font-semibold text-slate-500">{{ itemCount }} Konten</span>
                        <span class="text-primary group-hover:translate-x-1 transition-transform"><i data-lucide="arrow-right" class="w-5 h-5"></i></span>
                    </div>
                </div>
            </a>
        {% endfor %}
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('globalPageSearchInput');
        const grid = document.getElementById('contentGrid');
        const originalContent = grid ? grid.innerHTML : '';
        
        if (!searchInput || !grid) return;
        
        const collectionType = searchInput.getAttribute('data-collection');
        
        function renderSearchCard(item) {
            return `
            <a href="${item.url}" class="group block border border-border rounded-2xl overflow-hidden hover:border-primary hover:shadow-lg transition-all bg-surface h-full flex flex-col">
                <div class="h-48 relative overflow-hidden bg-slate-100 dark:bg-slate-800">
                    ${item.thumbnail ? `<img src="${item.thumbnail}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">` : ''}
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    <div class="absolute bottom-4 left-6">
                        <h2 class="text-2xl font-bold text-white mb-1">${item.title}</h2>
                    </div>
                </div>
                <div class="p-6 flex-grow flex flex-col">
                    <p class="text-textLight mb-6 leading-relaxed">${(item.description || '').substring(0, 100)}...</p>
                    <div class="mt-auto flex items-center text-primary font-medium group-hover:gap-2 transition-all">
                        <span>Jelajahi Topik</span>
                        <i data-lucide="arrow-right" class="w-4 h-4 ml-1"></i>
                    </div>
                </div>
            </a>`;
        }

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.trim().toLowerCase();
            
            if (!query) {
                grid.innerHTML = originalContent;
                lucide.createIcons();
                return;
            }
            
            fetch('/search.json')
                .then(res => res.json())
                .then(data => {
                    const results = data.filter(item => 
                        item.type === collectionType && 
                        (item.title.toLowerCase().includes(query) || item.description.toLowerCase().includes(query))
                    );
                    
                    if (results.length === 0) {
                        grid.innerHTML = `<p class="col-span-full text-center text-textLight py-8">Tidak ada hasil yang ditemukan untuk "<b>${query}</b>" di ${collectionType}.</p>`;
                        return;
                    }
                    
                    let html = '';
                    results.forEach(item => {
                        html += renderSearchCard(item);
                    });
                    
                    grid.innerHTML = html;
                    lucide.createIcons();
                });
        });
    });
</script>
