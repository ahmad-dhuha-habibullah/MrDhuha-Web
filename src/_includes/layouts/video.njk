---
layout: layouts/base.njk
---
<article class="container mx-auto px-4 lg:px-8 py-12 max-w-5xl">
    <div class="flex items-center gap-2 text-sm text-textLight mb-8">
        <a href="/" class="hover:text-primary">Beranda</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <a href="/video/" class="hover:text-primary">Video</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-text truncate">{{ title }}</span>
    </div>

    <!-- Video Player -->
    <div class="w-full aspect-video bg-slate-900 rounded-2xl mb-8 relative overflow-hidden shadow-lg">
        {% if youtube %}
            <iframe class="w-full h-full" src="https://www.youtube.com/embed/{{ youtube }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        {% else %}
            <!-- Fallback if no youtube ID is provided -->
            <img src="{{ thumbnail | resolveAsset(page.url) }}" class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay">
            <div class="absolute inset-0 flex items-center justify-center">
                <p class="text-white bg-black/50 px-4 py-2 rounded">Video tidak tersedia</p>
            </div>
        {% endif %}
    </div>

    <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-4">{{ title }}</h1>
        
        <div class="flex flex-wrap items-center justify-between gap-4 mb-8 border-b border-border pb-6">
            <div class="flex items-center gap-4">
                {% if series %}
                    <a href="/seri/{{ series | slugify }}/" class="bg-blue-100 text-blue-800 text-sm font-bold uppercase tracking-wider px-3 py-1 rounded-full hover:bg-blue-200 transition-colors">Series: {{ series }}</a>
                {% elif topic %}
                    <a href="/topik/{{ topic | slugify }}/" class="bg-orange-100 text-primary text-sm font-bold uppercase tracking-wider px-3 py-1 rounded-full hover:bg-orange-200 transition-colors">{{ topic }}</a>
                {% endif %}
                <span class="text-sm text-textLight">Diunggah {{ date | readableDate }}</span>
            </div>
            <div class="flex gap-2">
                <button onclick="window.openShareModal()" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-text bg-surface border border-border rounded-lg hover:bg-gray-100 transition-colors">
                    <i data-lucide="share-2" class="w-4 h-4"></i> Bagikan
                </button>
                <button onclick="toggleBookmark('{{ page.url }}', '{{ title | escape }}')" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-text bg-surface border border-border rounded-lg hover:bg-gray-100 transition-colors">
                    <i data-lucide="bookmark" class="w-4 h-4" id="bookmarkIcon"></i> <span id="bookmarkText">Simpan</span>
                </button>
            </div>
        </div>

        <div class="article-content bg-surface p-6 rounded-xl border border-border mb-12">
            <h3 class="text-lg font-bold mb-4 mt-0">Deskripsi</h3>
            {{ content | safe }}
        </div>
        
        <!-- Comments and Reactions (Giscus) -->
        <div class="mb-12 border-t border-border pt-8">
            <h3 class="font-bold text-2xl mb-6">Komentar & Diskusi</h3>
            <div class="giscus-container bg-surface border border-border p-6 rounded-2xl">
                <p class="text-textLight text-sm text-center mb-4">
                    <em>Catatan untuk Admin: Tempatkan script dari <strong>giscus.app</strong> di bawah baris ini untuk mengaktifkan fitur komentar dan Like.</em>
                </p>
                <!-- INSERT GISCUS SCRIPT HERE -->
                <script src="https://giscus.app/client.js"
                        data-repo="ahmad-dhuha-habibullah/MrDhuha-Web"
                        data-repo-id="REPLACE_ME_REPO_ID"
                        data-category="General"
                        data-category-id="REPLACE_ME_CATEGORY_ID"
                        data-mapping="pathname"
                        data-strict="0"
                        data-reactions-enabled="1"
                        data-emit-metadata="0"
                        data-input-position="bottom"
                        data-theme="preferred_color_scheme"
                        data-lang="id"
                        crossorigin="anonymous"
                        async>
                </script>
            </div>
        </div>
        
        <!-- Related Videos -->
        <div class="mt-16 pt-8 border-t border-border">
            <h3 class="font-bold text-2xl mb-6">Video Terkait</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {% set relatedCount = 0 %}
                {% for item in collections.videos %}
                    {% if item.url != page.url and relatedCount < 2 %}
                        <a href="{{ item.url }}" class="group flex gap-4 items-start">
                            {% if item.data.thumbnail %}
                            <div class="relative w-32 aspect-video flex-shrink-0 rounded-lg overflow-hidden bg-slate-900">
                                <img src="{{ item.data.thumbnail | resolveAsset(item.url) }}" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity">
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="w-8 h-8 bg-black/60 rounded-full flex items-center justify-center">
                                        <i data-lucide="play" class="w-4 h-4 text-white ml-0.5"></i>
                                    </div>
                                </div>
                            </div>
                            {% endif %}
                            <div>
                                <h4 class="text-base font-bold leading-tight group-hover:text-primary transition-colors mb-2">{{ item.data.title }}</h4>
                                <span class="text-sm text-textLight">{{ item.data.duration | default('Video') }}</span>
                            </div>
                        </a>
                        {% set relatedCount = relatedCount + 1 %}
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
</article>
