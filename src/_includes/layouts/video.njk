---
layout: layouts/base.njk
---
<article class="container mx-auto px-4 lg:px-8 py-12 max-w-5xl">
    <nav class="flex items-center gap-2 text-sm text-textLight mb-8">
        <a href="/" class="hover:text-primary transition-colors">Beranda</a>
        <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
        <a href="/video/" class="hover:text-primary transition-colors">Video</a>
        <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
        <span class="text-text font-medium truncate">{{ title }}</span>
    </nav>

    <!-- Video Player -->
    <div class="w-full aspect-video bg-slate-900 rounded-2xl mb-8 relative overflow-hidden shadow-lg">
        {% if youtube %}
            <iframe class="w-full h-full" src="https://www.youtube.com/embed/{{ youtube }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        {% else %}
            <!-- Fallback if no youtube ID is provided -->
            <img src="{{ thumbnail | resolveAsset(page.inputPath) }}" class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay">
            <div class="absolute inset-0 flex items-center justify-center">
                <p class="text-white bg-black/50 px-4 py-2 rounded">Video tidak tersedia</p>
            </div>
        {% endif %}
    </div>

    <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-4">{{ title }}</h1>
        
        <div class="flex flex-wrap items-center justify-between gap-4 mb-8 border-b border-border pb-6">
            <div class="flex items-center gap-4">
                {% if series %}
                    <a href="/seri/{{ series | slugify }}/" class="bg-blue-100 text-blue-800 text-sm font-bold uppercase tracking-wider px-3 py-1 rounded-full hover:bg-blue-200 transition-colors">Series: {{ series }}</a>
                {% elif topic %}
                    <a href="/topik/{{ topic | slugify }}/" class="bg-orange-100 text-primary text-sm font-bold uppercase tracking-wider px-3 py-1 rounded-full hover:bg-orange-200 transition-colors">{{ topic }}</a>
                {% endif %}
                <span class="text-sm text-textLight">Diunggah {{ date | readableDate }}</span>
            </div>
            <div class="flex gap-2">
                <button onclick="window.openShareModal()" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-text bg-surface border border-border rounded-lg hover:bg-slate-100 hover:text-slate-900 dark:hover:bg-slate-700 dark:hover:text-white transition-colors">
                    <i data-lucide="share-2" class="w-4 h-4"></i> Bagikan
                </button>
                <button onclick="toggleBookmark('{{ page.url }}', '{{ title | escape }}')" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-text bg-surface border border-border rounded-lg hover:bg-slate-100 hover:text-slate-900 dark:hover:bg-slate-700 dark:hover:text-white transition-colors">
                    <i data-lucide="bookmark" class="w-4 h-4" id="bookmarkIcon"></i> <span id="bookmarkText">Simpan</span>
                </button>
            </div>
        </div>

        <div class="article-content bg-surface p-6 rounded-xl border border-border mb-12">
            <h3 class="text-lg font-bold mb-4 mt-0">Deskripsi</h3>
            {{ content | safe }}
        </div>
        <!-- Series Navigation -->
        {% set parentSeries = title | getSeriesForTitle(collections) %}
        {% if parentSeries %}
            {% set seriesList = parentSeries.data.itemList | getResolvedList(collections) %}
            {% set prevInSeries = parentSeries.data.itemList | getAdjacentItem(title, 'prev', collections) %}
            {% set nextInSeries = parentSeries.data.itemList | getAdjacentItem(title, 'next', collections) %}
            
            <div class="mb-12 border-t border-border pt-8">
                <div class="bg-surface border border-primary/20 rounded-2xl overflow-hidden shadow-sm mb-8">
                    <div class="bg-primary/5 p-4 md:p-6 border-b border-primary/10 flex justify-between items-center">
                        <div>
                            <h3 class="font-bold text-lg text-primary flex items-center gap-2 mb-1">
                                <i data-lucide="layers" class="w-5 h-5"></i> Seri: {{ parentSeries.data.title }}
                            </h3>
                            <p class="text-sm text-textLight">{{ parentSeries.data.description | truncate(100) }}</p>
                        </div>
                        <a href="{{ parentSeries.url }}" class="hidden md:inline-flex px-3 py-1.5 text-xs font-bold bg-white dark:bg-slate-800 text-primary border border-primary/20 rounded-lg hover:bg-primary hover:text-white transition-colors">
                            Lihat Seri Lengkap
                        </a>
                    </div>
                    <div class="p-4 md:p-6 bg-slate-50/50 dark:bg-slate-900/20">
                        <h4 class="text-xs font-bold text-textLight uppercase tracking-widest mb-5">Peta Konten (Sitemap)</h4>
                        <ol class="space-y-4 relative before:absolute before:inset-y-3 before:left-[11px] md:before:left-[15px] before:w-[2px] before:bg-border">
                            {% for sItem in seriesList %}
                                {% set isActive = sItem.data.title == title %}
                                <li class="relative flex items-start gap-4">
                                    <div class="relative z-10 w-6 h-6 md:w-8 md:h-8 rounded-full flex-shrink-0 flex items-center justify-center font-bold text-xs md:text-sm border-2 {{ 'bg-primary border-primary text-white shadow-md shadow-primary/20' if isActive else 'bg-surface border-border text-textLight' }}">
                                        {{ loop.index }}
                                    </div>
                                    <div class="flex-1 pb-1 pt-0.5">
                                        {% if isActive %}
                                            <span class="block font-bold text-primary leading-tight">{{ sItem.data.title }}</span>
                                            <span class="text-[11px] font-semibold text-primary/70 mt-1 inline-block uppercase tracking-wider bg-primary/10 px-2 py-0.5 rounded-sm">Sedang diputar</span>
                                        {% else %}
                                            <a href="{{ sItem.url }}" class="block font-medium text-text hover:text-primary transition-colors leading-tight">{{ sItem.data.title }}</a>
                                        {% endif %}
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {% if prevInSeries %}
                    <a href="{{ prevInSeries.url }}" class="flex flex-col p-4 border border-border rounded-xl hover:bg-surface hover:border-primary/50 transition-all text-left group">
                        <span class="text-xs font-bold text-textLight uppercase tracking-wider mb-2 flex items-center gap-1"><i data-lucide="chevron-left" class="w-3 h-3"></i> Sebelumnya</span>
                        <span class="font-semibold text-text group-hover:text-primary transition-colors leading-tight">{{ prevInSeries.data.title }}</span>
                    </a>
                    {% else %}
                    <div></div>
                    {% endif %}
                    
                    {% if nextInSeries %}
                    <a href="{{ nextInSeries.url }}" class="flex flex-col p-4 border border-border rounded-xl hover:bg-surface hover:border-primary/50 transition-all text-right group">
                        <span class="text-xs font-bold text-textLight uppercase tracking-wider mb-2 flex items-center justify-end gap-1">Selanjutnya <i data-lucide="chevron-right" class="w-3 h-3"></i></span>
                        <span class="font-semibold text-text group-hover:text-primary transition-colors leading-tight">{{ nextInSeries.data.title }}</span>
                    </a>
                    {% else %}
                    <div></div>
                    {% endif %}
                </div>
            </div>
        {% endif %}

        <!-- Comments and Reactions (Giscus) -->
        <div class="mb-12 border-t border-border pt-8">
            <h3 class="font-bold text-2xl mb-6">Komentar & Diskusi</h3>
            <div class="giscus-container bg-surface border border-border p-6 rounded-2xl">
                <!-- INSERT GISCUS SCRIPT HERE -->
                <script src="https://giscus.app/client.js"
                        data-repo="ahmad-dhuha-habibullah/MrDhuha-Web"
                        data-repo-id="R_kgDOSzZ97Q"
                        data-category="General"
                        data-category-id="DIC_kwDOSzZ97S4C1e7c"
                        data-mapping="pathname"
                        data-strict="0"
                        data-reactions-enabled="1"
                        data-emit-metadata="0"
                        data-input-position="bottom"
                        data-theme="preferred_color_scheme"
                        data-lang="id"
                        crossorigin="anonymous"
                        async>
                </script>
            </div>
        </div>
        
        <!-- Related Videos -->
        <div class="mt-16 pt-8 border-t border-border">
            <h3 class="font-bold text-2xl mb-6">Video Terkait</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {% set relatedCount = 0 %}
                {% for item in collections.videos %}
                    {% if item.url != page.url and relatedCount < 2 %}
                        <a href="{{ item.url }}" class="group flex gap-4 items-start">
                            {% if item.data.thumbnail %}
                            <div class="relative w-32 aspect-video flex-shrink-0 rounded-lg overflow-hidden bg-slate-900">
                                <img src="{{ item.data.thumbnail | resolveAsset(item.inputPath) }}" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity">
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="w-8 h-8 bg-black/60 rounded-full flex items-center justify-center">
                                        <i data-lucide="play" class="w-4 h-4 text-white ml-0.5"></i>
                                    </div>
                                </div>
                            </div>
                            {% endif %}
                            <div>
                                <h4 class="text-base font-bold leading-tight group-hover:text-primary transition-colors mb-2">{{ item.data.title }}</h4>
                                <span class="text-sm text-textLight">{{ item.data.duration | default('Video') }}</span>
                            </div>
                        </a>
                        {% set relatedCount = relatedCount + 1 %}
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
</article>
