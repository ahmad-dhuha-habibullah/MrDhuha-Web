---
layout: layouts/base.njk
---

<div class="container mx-auto px-4 lg:px-8 py-4">
    <nav class="flex items-center gap-2 text-sm text-textLight">
        <a href="/" class="hover:text-primary transition-colors">Beranda</a>
        <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
        <a href="/eksplorasi/" class="hover:text-primary transition-colors">Eksplorasi</a>
        <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
        <span class="text-text font-medium truncate">{{ title }}</span>
    </nav>
</div>

{% set bgImage = heroImage | default(thumbnail) %}
<div class="relative bg-slate-900 text-white border-b border-white/10 py-16 overflow-hidden">
    {% if bgImage %}
    <div class="absolute inset-0 z-0">
        <img src="{{ bgImage }}" alt="{{ title }}" class="w-full h-full object-cover opacity-20">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 to-transparent"></div>
    </div>
    {% endif %}
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
            <span class="inline-block bg-blue-500/20 text-blue-200 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest mb-4 border border-blue-400/30">{{ type | default('Visualisasi') }}</span>
            <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-6">{{ title }}</h1>
            <p class="text-lg md:text-xl text-slate-300 font-serif">{{ description }}</p>

            <div class="flex justify-center gap-2 mt-8">
                <button onclick="window.openShareModal()" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-text border border-border bg-surface rounded-lg hover:bg-slate-100 hover:text-slate-900 dark:hover:bg-slate-700 dark:hover:text-white transition-colors shadow-sm">
                    <i data-lucide="share-2" class="w-4 h-4"></i> Bagikan
                </button>
                <button onclick="toggleBookmark('{{ page.url }}', '{{ title | escape }}')" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-text border border-border bg-surface rounded-lg hover:bg-slate-100 hover:text-slate-900 dark:hover:bg-slate-700 dark:hover:text-white transition-colors shadow-sm">
                    <i data-lucide="bookmark" class="w-4 h-4" id="bookmarkIcon"></i> <span id="bookmarkText">Simpan</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="w-full bg-slate-100 dark:bg-slate-800/50 border-b border-border">
    <!-- Exploration Interactive Content Area -->
    <div class="container mx-auto px-0 md:px-4 lg:px-8 py-8">
        <div id="iframeContainer" class="relative group bg-surface shadow-xl rounded-none md:rounded-2xl border border-border overflow-hidden flex items-center justify-center" style="min-height: 60vh;">
            {% if iframe %}
                <!-- Action Bar Overlay (Right) -->
                <div class="absolute top-4 right-4 z-10 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <a href="{{ iframe }}" target="_blank" rel="noopener noreferrer" class="bg-black/70 hover:bg-black text-white px-3 py-1.5 rounded-lg text-sm font-medium backdrop-blur-sm transition-colors flex items-center gap-1.5 shadow-lg">
                        <i data-lucide="external-link" class="w-4 h-4"></i> <span class="hidden sm:inline">Visit Page</span>
                    </a>
                    <button onclick="toggleIframeFullscreen()" id="fullscreenBtn" class="bg-black/70 hover:bg-black text-white px-3 py-1.5 rounded-lg text-sm font-medium backdrop-blur-sm transition-colors flex items-center gap-1.5 shadow-lg">
                        <i data-lucide="maximize" class="w-4 h-4" id="fullscreenIcon"></i> <span class="hidden sm:inline" id="fullscreenText">Full Screen</span>
                    </button>
                </div>

                <!-- Navigation Bar Overlay (Left) -->
                <div class="absolute top-4 left-4 z-10 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <button onclick="navigateIframe(-1)" class="bg-black/70 hover:bg-black text-white px-2 py-1.5 rounded-lg text-sm font-medium backdrop-blur-sm transition-colors flex items-center shadow-lg" title="Kembali">
                        <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    </button>
                    <button onclick="navigateIframe(1)" class="bg-black/70 hover:bg-black text-white px-2 py-1.5 rounded-lg text-sm font-medium backdrop-blur-sm transition-colors flex items-center shadow-lg" title="Maju">
                        <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </button>
                    <button onclick="document.getElementById('exploreFrame').src = document.getElementById('exploreFrame').src" class="bg-black/70 hover:bg-black text-white px-2 py-1.5 rounded-lg text-sm font-medium backdrop-blur-sm transition-colors flex items-center shadow-lg" title="Muat Ulang">
                        <i data-lucide="rotate-cw" class="w-4 h-4"></i>
                    </button>
                </div>

                <iframe id="exploreFrame" src="{{ iframe }}" class="absolute inset-0 w-full h-full border-0" allowfullscreen></iframe>
            {% else %}
                <div class="text-center p-8">
                    <i data-lucide="wrench" class="w-16 h-16 text-slate-300 mx-auto mb-4"></i>
                    <p class="text-slate-500 font-medium">Sedang Dalam Perbaikan (Under Maintenance)</p>
                    <p class="text-sm text-slate-400 mt-2">Visualisasi interaktif ini sedang dalam tahap pengembangan.</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="container mx-auto px-4 lg:px-8 py-16">
    <div class="max-w-3xl mx-auto prose prose-lg prose-slate dark:prose-invert prose-a:text-primary hover:prose-a:text-orange-700">
        {{ content | safe }}
    </div>

    <!-- Lihat Juga (Related Explorations) -->
    <div class="mt-16 pt-8 border-t border-border max-w-3xl mx-auto">
        <h3 class="font-bold text-2xl mb-6">Lihat Juga Eksplorasi Lainnya</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% set relatedCount = 0 %}
            {% for item in collections.explorations %}
                {% if item.url != page.url and relatedCount < 2 %}
                    <a href="{{ item.url }}" class="group flex gap-4 items-center bg-surface border border-border p-3 rounded-xl hover:shadow-md transition-all">
                        {% if item.data.thumbnail %}
                        <img src="{{ item.data.thumbnail | resolveAsset(item.inputPath) }}" class="w-20 h-20 object-cover rounded-lg flex-shrink-0">
                        {% endif %}
                        <div>
                            <h4 class="font-bold text-sm group-hover:text-primary transition-colors leading-snug mb-1">{{ item.data.title }}</h4>
                            <p class="text-xs text-textLight">{{ item.data.type | default('Eksplorasi') }}</p>
                        </div>
                    </a>
                    {% set relatedCount = relatedCount + 1 %}
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>

<script>
    function toggleIframeFullscreen() {
        const container = document.getElementById('iframeContainer');
        const icon = document.getElementById('fullscreenIcon');
        const text = document.getElementById('fullscreenText');

        if (!document.fullscreenElement) {
            if (container.requestFullscreen) {
                container.requestFullscreen();
            } else if (container.webkitRequestFullscreen) { /* Safari */
                container.webkitRequestFullscreen();
            } else if (container.msRequestFullscreen) { /* IE11 */
                container.msRequestFullscreen();
            }
        } else {
            if (document.exitFullscreen) {
                document.exitFullscreen();
            } else if (document.webkitExitFullscreen) { /* Safari */
                document.webkitExitFullscreen();
            } else if (document.msExitFullscreen) { /* IE11 */
                document.msExitFullscreen();
            }
        }
    }

    // Listen for fullscreen change to update the button UI
    document.addEventListener('fullscreenchange', (event) => {
        const icon = document.getElementById('fullscreenIcon');
        const text = document.getElementById('fullscreenText');
        
        if (document.fullscreenElement) {
            // Entered fullscreen
            icon.setAttribute('data-lucide', 'minimize');
            text.innerText = 'Minimize';
        } else {
            // Exited fullscreen
            icon.setAttribute('data-lucide', 'maximize');
            text.innerText = 'Full Screen';
        }
        lucide.createIcons();
    });

    function navigateIframe(direction) {
        const iframe = document.getElementById('exploreFrame');
        try {
            if (direction === -1) {
                iframe.contentWindow.history.back();
            } else if (direction === 1) {
                iframe.contentWindow.history.forward();
            }
        } catch (e) {
            console.warn("Iframe navigation blocked due to cross-origin restrictions.", e);
            // Optional: fallback UI notification here
            showToast("Navigasi iframe diblokir karena beda domain.");
        }
    }
</script>
