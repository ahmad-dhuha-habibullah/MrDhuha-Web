---
layout: layouts/base.njk
---

<div class="bg-slate-50 dark:bg-slate-900/50 border-b border-border py-12">
    <div class="container mx-auto px-4 lg:px-8">
        <div class="max-w-4xl mx-auto text-center">
            <div class="flex items-center justify-center gap-2 text-sm text-textLight mb-6">
                <a href="/" class="hover:text-primary">Beranda</a>
                <i data-lucide="chevron-right" class="w-4 h-4"></i>
                <a href="/eksplorasi/" class="hover:text-primary">Eksplorasi</a>
                <i data-lucide="chevron-right" class="w-4 h-4"></i>
                <span class="text-text font-semibold truncate">{{ title }}</span>
            </div>
            
            <span class="inline-block bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest mb-4">{{ type | default('Visualisasi') }}</span>
            <h1 class="text-3xl md:text-5xl font-extrabold text-text mb-6">{{ title }}</h1>
            <p class="text-lg md:text-xl text-textLight font-serif">{{ description }}</p>
        </div>
    </div>
</div>

<div class="w-full bg-slate-100 dark:bg-slate-800/50 border-b border-border">
    <!-- Exploration Interactive Content Area -->
    <div class="container mx-auto px-0 md:px-4 lg:px-8 py-8">
        <div class="aspect-video bg-surface shadow-xl rounded-none md:rounded-2xl border border-border overflow-hidden relative flex items-center justify-center">
            {% if iframe %}
                <iframe src="{{ iframe }}" class="w-full h-full border-0" allowfullscreen></iframe>
            {% else %}
                <div class="text-center p-8">
                    <i data-lucide="wrench" class="w-16 h-16 text-slate-300 mx-auto mb-4"></i>
                    <p class="text-slate-500 font-medium">Sedang Dalam Perbaikan (Under Maintenance)</p>
                    <p class="text-sm text-slate-400 mt-2">Visualisasi interaktif ini sedang dalam tahap pengembangan.</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="container mx-auto px-4 lg:px-8 py-16">
    <div class="max-w-3xl mx-auto prose prose-lg prose-slate dark:prose-invert prose-a:text-primary hover:prose-a:text-orange-700">
        {{ content | safe }}
    </div>
</div>
