---
layout: layouts/base.njk
---
{% from "components/macros.njk" import contentCard %}

<div class="container mx-auto px-4 lg:px-8 py-4">
    <nav class="flex items-center gap-2 text-sm text-textLight">
        <a href="/" class="hover:text-primary transition-colors">Beranda</a>
        <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
        <a href="/seri/" class="hover:text-primary transition-colors">Series</a>
        <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
        <span class="text-text font-medium">{{ title }}</span>
    </nav>
</div>

{% set bgImage = heroImage | default(thumbnail) %}
<div class="bg-slate-900 text-white py-16 lg:py-24 border-b border-white/10 relative overflow-hidden">
    {% if bgImage %}
    <div class="absolute inset-0 z-0">
        <img src="{{ bgImage }}" alt="{{ title }}" class="w-full h-full object-cover opacity-20">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 to-transparent"></div>
    </div>
    {% endif %}
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
        <div class="max-w-3xl">
            <span class="text-primary font-bold tracking-wider uppercase text-sm mb-4 block">Series</span>
            <h1 class="text-4xl md:text-5xl font-extrabold mb-6">{{ title }}</h1>
            <p class="text-xl text-gray-300 font-serif leading-relaxed mb-8">{{ description }}</p>
            <div class="flex items-center gap-4 text-sm text-gray-400">
                {% set itemCount = (itemList | default([])) | length %}
                <span class="bg-surface/10 px-3 py-1 rounded-full">{{ itemCount }} Bagian</span>
            </div>
        </div>
    </div>
</div>

<div class="container mx-auto px-4 lg:px-8 py-16">
    <div class="max-w-4xl">
        <h2 class="text-2xl font-bold text-text mb-8">Daftar Konten dalam Series Ini</h2>
        
        <div class="space-y-6">
            {% set step = 1 %}
            {% set seriesItems = itemList | getResolvedList(collections) %}
            
            {% for item in seriesItems %}
                {% set isVideo = "videos" in item.inputPath %}
                <div class="flex gap-6 group bg-surface border border-border p-6 rounded-2xl hover:shadow-lg transition-shadow">
                    {% if isVideo %}
                    <div class="w-12 h-12 rounded-full bg-orange-50 text-orange-600 font-bold flex items-center justify-center flex-shrink-0 text-xl border border-orange-100 group-hover:bg-orange-600 group-hover:text-white transition-colors">
                        {{ step }}
                    </div>
                    {% else %}
                    <div class="w-12 h-12 rounded-full bg-blue-50 text-primary font-bold flex items-center justify-center flex-shrink-0 text-xl border border-blue-100 group-hover:bg-primary group-hover:text-white transition-colors">
                        {{ step }}
                    </div>
                    {% endif %}
                    
                    <div>
                        <a href="{{ item.url }}" class="block mb-2">
                            <h3 class="text-xl font-bold text-text group-hover:text-primary transition-colors">{{ item.data.title }}</h3>
                        </a>
                        <p class="text-textLight mb-3">{{ item.data.description }}</p>
                        <div class="flex items-center gap-3 text-xs text-textLight">
                            {% if isVideo %}
                            <span class="flex items-center gap-1"><i data-lucide="play-circle" class="w-3 h-3"></i> Video</span>
                            {% else %}
                            <span class="flex items-center gap-1"><i data-lucide="book-open" class="w-3 h-3"></i> Artikel</span>
                            {% endif %}
                            <span>&middot;</span>
                            <span>{{ item.data.topic }}</span>
                        </div>
                    </div>
                </div>
                {% set step = step + 1 %}
            {% endfor %}
            
            {% if step == 1 %}
                <p class="text-textLight italic">Konten untuk series ini sedang dipersiapkan.</p>
            {% endif %}
        </div>
    </div>
</div>
