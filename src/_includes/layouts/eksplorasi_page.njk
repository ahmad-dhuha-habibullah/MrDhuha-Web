---
layout: layouts/base.njk
---

<div class="container mx-auto px-4 lg:px-8 py-12">
    <div class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <nav class="flex items-center gap-2 text-sm text-textLight mb-4">
                <a href="/" class="hover:text-primary transition-colors">Beranda</a>
                <span><i data-lucide="chevron-right" class="w-4 h-4"></i></span>
                <span class="text-text font-medium truncate">Eksplorasi</span>
            </nav>
            <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-4">{{ page_heading }}</h1>
            <p class="text-lg text-textLight max-w-2xl font-serif">{{ page_description }}</p>
        </div>
        
        <div class="w-full md:w-64 relative">
            <input type="text" id="globalPageSearchInput" data-collection="Eksplorasi" placeholder="Cari eksplorasi..." class="w-full bg-surface border border-border rounded-full py-2 px-4 pr-10 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-text">
            <i data-lucide="search" class="absolute right-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-textLight"></i>
        </div>
    </div>

    {% if content %}
    <!-- CMS WYSIWYG Content -->
    <div class="prose prose-lg prose-slate dark:prose-invert max-w-4xl mx-auto mb-16">
        {{ content | safe }}
    </div>
    {% endif %}

    <!-- Content Grid -->
    <div id="contentGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {% for item in collections.explorations %}
            <article class="bg-surface border border-border rounded-xl overflow-hidden hover:shadow-lg transition-shadow group flex flex-col">
                <a href="{{ item.url }}" class="block relative aspect-video bg-gray-100 dark:bg-slate-800 overflow-hidden">
                    {% if item.data.thumbnail %}
                    <img src="{{ item.data.thumbnail | resolveAsset(item.inputPath) }}" alt="{{ item.data.title }}" class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500">
                    {% endif %}
                    <div class="absolute top-4 left-4 bg-surface/90 backdrop-blur-sm px-3 py-1 rounded text-xs font-bold text-primary uppercase tracking-wider">
                        {{ item.data.type | default('Eksplorasi') }}
                    </div>
                </a>
                <div class="p-5 flex flex-col flex-grow">
                    <a href="{{ item.url }}" class="block group-hover:text-primary transition-colors">
                        <h3 class="font-bold text-lg leading-snug mb-2">{{ item.data.title }}</h3>
                    </a>
                    <p class="text-sm text-textLight mb-4">{{ item.data.description | default('') | truncate(80) }}</p>
                    <div class="mt-auto flex items-center justify-between text-sm text-textLight">
                        <span>
                            {% if item.date %}
                                {{ item.date | readableDate }}
                            {% else %}
                                Interaktif
                            {% endif %}
                        </span>
                        <button class="bookmark-btn-card hover:text-primary z-10 relative" aria-label="Simpan" data-bookmark-url="{{ item.url }}" onclick="event.preventDefault(); toggleBookmark('{{ item.url }}', '{{ item.data.title | escape }}')"><i data-lucide="bookmark" class="w-4 h-4"></i></button>
                    </div>
                </div>
            </article>
        {% else %}
            <p class="text-textLight">Belum ada eksplorasi yang ditambahkan.</p>
        {% endfor %}
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('globalPageSearchInput');
        const grid = document.getElementById('contentGrid');
        const originalContent = grid ? grid.innerHTML : '';
        
        if (!searchInput || !grid) return;
        
        const collectionType = searchInput.getAttribute('data-collection');
        
        function renderSearchCard(item) {
            return `
            <article class="bg-surface border border-border rounded-xl overflow-hidden hover:shadow-lg transition-shadow group flex flex-col h-full">
                <a href="${item.url}" class="block relative aspect-video bg-gray-100 dark:bg-slate-800 overflow-hidden">
                    ${item.thumbnail ? `<img src="${item.thumbnail}" alt="${item.title}" class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500">` : ''}
                    <div class="absolute top-4 left-4 bg-surface/90 backdrop-blur-sm px-3 py-1 rounded text-xs font-bold text-primary uppercase tracking-wider">
                        ${item.type || 'Eksplorasi'}
                    </div>
                </a>
                <div class="p-5 flex flex-col flex-grow">
                    <a href="${item.url}" class="block group-hover:text-primary transition-colors">
                        <h3 class="font-bold text-lg leading-snug mb-2">${item.title}</h3>
                    </a>
                    <p class="text-sm text-textLight mb-4">${(item.description || '').substring(0, 80)}...</p>
                    <div class="mt-auto">
                        <a href="${item.url}" class="inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-orange-700 transition-colors">
                            Mulai eksplorasi <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </a>
                    </div>
                </div>
            </article>`;
        }

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.trim().toLowerCase();
            
            if (!query) {
                grid.innerHTML = originalContent;
                lucide.createIcons();
                return;
            }
            
            fetch('/search.json')
                .then(res => res.json())
                .then(data => {
                    const results = data.filter(item => 
                        item.type === collectionType && 
                        (item.title.toLowerCase().includes(query) || item.description.toLowerCase().includes(query))
                    );
                    
                    if (results.length === 0) {
                        grid.innerHTML = `<p class="col-span-full text-center text-textLight py-8">Tidak ada hasil yang ditemukan untuk "<b>${query}</b>" di ${collectionType}.</p>`;
                        return;
                    }
                    
                    let html = '';
                    results.forEach(item => {
                        html += renderSearchCard(item);
                    });
                    
                    grid.innerHTML = html;
                    lucide.createIcons();
                });
        });
    });
</script>
