---
permalink: /search.json
---
[
  {% set comma = false %}
  
  {% for item in collections.articles %}
  {% if comma %},{% endif %}
  {
    "title": "{{ item.data.title | replace('"', '\\"') }}",
    "url": "{{ item.url }}",
    "type": "Artikel",
    "topic": "{{ item.data.topic }}",
    "description": "{{ item.data.description | replace('"', '\\"') }}",
    "thumbnail": "{{ item.data.thumbnail }}",
    "date": "{{ item.date }}"
  }
  {% set comma = true %}
  {% endfor %}
  
  {% for item in collections.videos %}
  {% if comma %},{% endif %}
  {
    "title": "{{ item.data.title | replace('"', '\\"') }}",
    "url": "{{ item.url }}",
    "type": "Video",
    "topic": "{{ item.data.topic }}",
    "description": "{{ item.data.description | replace('"', '\\"') }}",
    "thumbnail": "{{ item.data.thumbnail }}",
    "date": "{{ item.date }}"
  }
  {% set comma = true %}
  {% endfor %}

  {% for item in collections.explorations %}
  {% if comma %},{% endif %}
  {
