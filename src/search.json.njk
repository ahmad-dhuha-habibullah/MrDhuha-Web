    "description": "{{ item.data.description | replace('"', '\\"') }}",
    "thumbnail": "{{ item.data.thumbnail }}"
  }
  {% set comma = true %}
  {% endfor %}

  {% for item in collections.series %}
  {% if comma %},{% endif %}
  {
    "title": "{{ item.data.title | replace('"', '\\"') }}",
    "url": "{{ item.url }}",
    "type": "Series",
    "description": "{{ item.data.description | replace('"', '\\"') }}",
    "thumbnail": "{{ item.data.thumbnail }}"
  }
  {% set comma = true %}
  {% endfor %}

  {% for item in collections.topics %}
  {% if comma %},{% endif %}
  {
    "title": "{{ item.data.title | replace('"', '\\"') }}",
    "url": "{{ item.url }}",
    "type": "Topik",
    "description": "{{ item.data.description | replace('"', '\\"') }}",
