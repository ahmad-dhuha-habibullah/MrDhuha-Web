---
pagination:
  data: collections.topics
  size: 1
  alias: topic
layout: layouts/base.njk
permalink: "/topik/{{ topic | slugify }}/"
eleventyComputed:
  title: "Topik: {{ topic }} - Mr Dhuha"
---
{% from "components/macros.njk" import contentCard %}

<div class="container mx-auto px-4 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-12">
        <div class="flex items-center gap-2 text-sm text-textLight mb-4">
            <a href="/" class="hover:text-primary">Beranda</a>
            <i data-lucide="chevron-right" class="w-4 h-4"></i>
            <a href="/topik/" class="hover:text-primary">Topik</a>
            <i data-lucide="chevron-right" class="w-4 h-4"></i>
            <span class="text-text">{{ topic }}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-4">{{ topic }}</h1>
    </div>

    <h2 class="text-2xl font-bold text-text mb-6">Artikel & Video</h2>
    <!-- Content Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {% for item in collections.articles %}
            {% if item.data.topic == topic %}
                {{ contentCard(item) }}
            {% endif %}
        {% endfor %}
        
        {% for item in collections.videos %}
            {% if item.data.topic == topic %}
                {{ contentCard(item, true) }}
            {% endif %}
        {% endfor %}
    </div>
</div>
