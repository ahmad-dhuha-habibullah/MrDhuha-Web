---
layout: layouts/base.njk
title: Pencarian - Mr Dhuha
---

<div class="container mx-auto px-4 lg:px-8 py-12 max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-8">Pencarian</h1>
    
    <div class="mb-8">
        <input type="text" id="searchInput" placeholder="Cari artikel, video, atau topik..." class="w-full px-4 py-3 rounded-xl border border-border focus:outline-none focus:ring-2 focus:ring-primary/50 text-lg">
    </div>

    <div id="searchResults" class="space-y-4 mb-12 hidden">
        <!-- Results will be injected here -->
    </div>

    <div id="bookmarksSection" class="mt-8 border-t border-border pt-8">
        <h2 class="text-2xl font-bold text-text mb-4 flex items-center gap-2">
            <i data-lucide="bookmark" class="w-6 h-6 text-primary"></i> Tersimpan (Markah)
        </h2>
        <div id="bookmarksList" class="space-y-4">
            <p class="text-textLight">Belum ada konten yang disimpan.</p>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const searchInput = document.getElementById('searchInput');
        const searchResults = document.getElementById('searchResults');
        
        let index = [];
        try {
            const response = await fetch('/search.json');
            index = await response.json();
        } catch (error) {
            console.error('Error loading search index:', error);
            searchResults.innerHTML = '<p class="text-red-500">Gagal memuat indeks pencarian.</p>';
            return;
        }

        const bookmarksSection = document.getElementById('bookmarksSection');
        const bookmarksList = document.getElementById('bookmarksList');

        function renderBookmarks() {
            let bookmarks = JSON.parse(localStorage.getItem('mrdhuha_bookmarks') || '[]');
            if (bookmarks.length === 0) {
                bookmarksList.innerHTML = '<p class="text-textLight">Belum ada konten yang disimpan. Klik tombol "Simpan" pada artikel atau video untuk menyimpannya di sini.</p>';
                return;
            }

            bookmarksList.innerHTML = bookmarks.reverse().map(item => `
                <div class="flex items-center justify-between p-4 border border-border rounded-xl hover:border-primary transition-colors bg-surface group">
                    <a href="${item.url}" class="flex-grow pr-4">
                        <h3 class="text-lg font-bold text-text mb-1 group-hover:text-primary transition-colors">${item.title}</h3>
                        <p class="text-xs text-textLight">Disimpan pada ${new Date(item.date).toLocaleDateString('id-ID')}</p>
                    </a>
                    <button onclick="removeBookmark('${item.url}')" class="p-2 text-textLight hover:text-red-500 transition-colors" title="Hapus dari markah">
                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                    </button>
                </div>
            `).join('');
            lucide.createIcons();
        }

        window.removeBookmark = function(url) {
            let bookmarks = JSON.parse(localStorage.getItem('mrdhuha_bookmarks') || '[]');
            bookmarks = bookmarks.filter(b => b.url !== url);
            localStorage.setItem('mrdhuha_bookmarks', JSON.stringify(bookmarks));
            renderBookmarks();
            if (typeof updateBookmarkUI === 'function') updateBookmarkUI();
        };

        renderBookmarks();

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            if (query.length < 2) {
                searchResults.classList.add('hidden');
                bookmarksSection.classList.remove('hidden');
                return;
            }

            searchResults.classList.remove('hidden');
            bookmarksSection.classList.add('hidden');

            const results = index.filter(item => {
                return item.title.toLowerCase().includes(query) || 
                       item.description.toLowerCase().includes(query) ||
                       (item.topic && item.topic.toLowerCase().includes(query));
            });

            if (results.length === 0) {
                searchResults.innerHTML = '<p class="text-textLight">Tidak ada hasil yang ditemukan untuk "' + query + '".</p>';
                return;
            }

            searchResults.innerHTML = results.map(item => `
                <a href="${item.url}" class="block p-4 border border-border rounded-xl hover:border-primary transition-colors bg-surface">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="text-xs font-bold text-primary uppercase">${item.type}</span>
                        ${item.topic ? `<span class="text-xs text-textLight">&middot; ${item.topic}</span>` : ''}
                    </div>
                    <h3 class="text-lg font-bold text-text mb-2">${item.title}</h3>
                    <p class="text-sm text-textLight">${item.description}</p>
                </a>
            `).join('');
        });
    });
</script>
