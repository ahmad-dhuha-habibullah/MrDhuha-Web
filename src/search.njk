---
layout: layouts/base.njk
title: Pencarian - Mr Dhuha
---

<div class="container mx-auto px-4 lg:px-8 py-12 max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-extrabold text-text mb-8">Pencarian</h1>
    
    <div class="mb-8">
        <input type="text" id="searchInput" placeholder="Cari artikel, video, atau topik..." class="w-full px-4 py-3 rounded-xl border border-border focus:outline-none focus:ring-2 focus:ring-primary/50 text-lg">
    </div>

    <div id="searchResults" class="space-y-4">
        <!-- Results will be injected here -->
        <p class="text-textLight">Ketikkan kata kunci untuk mulai mencari.</p>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const searchInput = document.getElementById('searchInput');
        const searchResults = document.getElementById('searchResults');
        
        let index = [];
        try {
            const response = await fetch('/search.json');
            index = await response.json();
        } catch (error) {
            console.error('Error loading search index:', error);
            searchResults.innerHTML = '<p class="text-red-500">Gagal memuat indeks pencarian.</p>';
            return;
        }

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            if (query.length < 2) {
                searchResults.innerHTML = '<p class="text-textLight">Ketikkan minimal 2 karakter untuk mencari.</p>';
                return;
            }

            const results = index.filter(item => {
                return item.title.toLowerCase().includes(query) || 
                       item.description.toLowerCase().includes(query) ||
                       (item.topic && item.topic.toLowerCase().includes(query));
            });

            if (results.length === 0) {
                searchResults.innerHTML = '<p class="text-textLight">Tidak ada hasil yang ditemukan untuk "' + query + '".</p>';
                return;
            }

            searchResults.innerHTML = results.map(item => `
                <a href="${item.url}" class="block p-4 border border-border rounded-xl hover:border-primary transition-colors bg-surface">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="text-xs font-bold text-primary uppercase">${item.type}</span>
                        ${item.topic ? `<span class="text-xs text-textLight">&middot; ${item.topic}</span>` : ''}
                    </div>
                    <h3 class="text-lg font-bold text-text mb-2">${item.title}</h3>
                    <p class="text-sm text-textLight">${item.description}</p>
                </a>
            `).join('');
        });
    });
</script>
